{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/index.html", "/manifest.webmanifest", "/*.css", "/*.js", "/assets/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-products-cache",
      "urls": ["/api/products", "http://localhost:8080/api/products"],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "1d",
        "strategy": "freshness",
        "timeout": "5s"
      }
    }
  ]
}
